{
  "name": "pharos-ecosystem-asset-tracker",
  "version": "1.0.0",
  "description": "A skill-based asset tracker for the Pharos Network (chain 1672) ecosystem — native PROS, ERC-20 tokens, NFTs, DeFi positions, and AI-powered portfolio insights.",
  "type": "module",
  "main": "skills/pharos-tracker/index.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch skills/pharos-tracker/main.ts",
    "check": "tsc --noEmit",
    "wallet": "tsx skills/pharos-tracker/tools/walletBalance.ts",
    "tokens": "tsx skills/pharos-tracker/tools/tokenAssets.ts",
    "portfolio": "tsx skills/pharos-tracker/ai/portfolioSummary.ts",
    "demo": "tsx main.ts"
  },
  "keywords": [
    "pharos",
    "pros",
    "real-fi",
    "rwa",
    "asset-tracker",
    "wallet",
    "defi"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "dotenv": "^16.4.0",
    "ethers": "^6.13.0",
    "viem": "^2.21.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
